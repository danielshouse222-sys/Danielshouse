# Daniel's House — Cloudflare Workers Static Assets redirects
# Format: <from> <to> <status>
#   200 = rewrite (URL stays the same, different file served)
#   301 = permanent redirect
#
# Cloudflare does NOT accept 404 here. The 404 fallback for missing
# routes is handled by wrangler.jsonc's `not_found_handling: "404-page"`
# setting, which auto-serves /404.html with a 404 status.

# Trailing-slash normalization
/skincare/    /skincare.html       200
/supplements/ /supplements.html    200
