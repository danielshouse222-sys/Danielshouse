# Cloudflare Workers static assets — files to exclude from the upload.
# Uses gitignore syntax. Same purpose as .gitignore but for the assets
# directory at deploy time.

# Git internals (the .pack file is what's blowing past Workers' 25 MiB
# per-asset limit and breaking the deploy)
.git/
.gitignore
.gitattributes

# Build & deploy tooling — not runtime assets
bump-version.sh
bump-version.py
netlify.toml
wrangler.jsonc
wrangler.toml
.assetsignore

# Documentation & project files
*.md
LICENSE
LICENSE.txt

# Misc dev artifacts
*.zip
*.bak
.DS_Store
node_modules/
.env
.env.*
