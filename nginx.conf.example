# Daniel's House — Nginx Cache Strategy
# Include this in your server block. Place in /etc/nginx/sites-available/ or similar.
#
# Strategy: HTML never cached, versioned assets cached forever.

server {
    # ... your existing server config (listen, server_name, root, etc.)

    # ─── HTML: no cache ───
    location ~* \.(html|htm)$ {
        add_header Cache-Control "public, max-age=0, must-revalidate";
        add_header X-Content-Type-Options "nosniff";
        add_header X-Frame-Options "SAMEORIGIN";
        add_header Referrer-Policy "strict-origin-when-cross-origin";
    }

    # ─── Root index: no cache ───
    location = / {
        add_header Cache-Control "public, max-age=0, must-revalidate";
    }

    # ─── Data files (products, bundles, FAQ, ingredients) — always revalidate ───
    # These hold content that changes between deploys. The `^~` prefix gives
    # this prefix match higher priority than the regex .js match below.
    location ^~ /data/ {
        add_header Cache-Control "public, no-cache, must-revalidate";
    }

    # ─── JS and CSS: cache forever (URL changes on deploy) ───
    location ~* \.(css|js)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    # ─── Images: 30 days ───
    location ~* \.(jpg|jpeg|png|gif|webp|svg|ico)$ {
        add_header Cache-Control "public, max-age=2592000";
        access_log off;
    }

    # ─── Fonts: 1 year ───
    location ~* \.(woff|woff2|ttf|otf|eot)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    # ─── Compression ───
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml;
}
