# Daniel's House — Netlify Cache Headers
# Place this file at the root of your deploy.
#
# Strategy:
#   HTML       → no-cache (always check for updates)
#   Versioned  → cache 1 year (URL changes when ?v=... changes)
#   Images     → cache 30 days (long, but reasonable)
#   Fonts      → cache 1 year (rarely change)

# All HTML — never cached
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

# Root index too
/
  Cache-Control: public, max-age=0, must-revalidate

# Static assets with ?v= query — cache forever (the URL changes on deploy)
/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# Data files (products, bundles, FAQ, ingredients) — always revalidate.
# These hold content that changes between deploys. Browsers and CDNs MAY
# cache them, but MUST revalidate with the origin before reuse. Returns
# 304 Not Modified on no-change (tiny response), 200 with fresh body on
# change. Eliminates the "I updated content but it's not showing" problem
# at the cost of a small revalidation round-trip per page load.
/data/*
  Cache-Control: public, no-cache, must-revalidate

# Images — long cache, gets refreshed if filename changes
/images/*
  Cache-Control: public, max-age=2592000

/products/*
  Cache-Control: public, max-age=2592000

# Fonts — cache forever
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
